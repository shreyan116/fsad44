    <script>
        // Particles Background
        function initParticles() {
            const particlesContainer = document.getElementById('particles-js');
            const particleCount = 100;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.style.position = 'absolute';
                particle.style.width = Math.random() * 5 + 'px';
                particle.style.height = particle.style.width;
                particle.style.background = `rgba(${Math.random() * 100 + 100}, ${Math.random() * 100 + 100}, 255, ${Math.random() * 0.5})`;
                particle.style.borderRadius = '50%';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.animation = `float ${Math.random() * 10 + 10}s linear infinite`;
                particle.style.pointerEvents = 'none';
                particlesContainer.appendChild(particle);
            }
        }

        let currentUserType = 'admin';

        function setUserType(type) {
            currentUserType = type;
            document.querySelectorAll('.user-type button').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
        }

        function login() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            if (!email || !password) {
                alert('🚀 Please enter your credentials to launch!');
                return;
            }

            // Simple animation for login
            const loginBox = document.querySelector('.login-box');
            loginBox.style.transform = 'scale(0.95)';
            setTimeout(() => {
                loginBox.style.transform = 'scale(1)';
                
                document.getElementById('loginPage').style.display = 'none';
                
                if (currentUserType === 'admin') {
                    document.getElementById('adminDashboard').style.display = 'block';
                    showNotification('Welcome back, Admin! 🎉', 'success');
                } else if (currentUserType === 'student') {
                    document.getElementById('studentDashboard').style.display = 'block';
                    showNotification('Welcome to your journey, John! 🌟', 'success');
                } else if (currentUserType === 'parent') {
                    showNotification('Parent portal coming soon!', 'info');
                } else if (currentUserType === 'teacher') {
                    showNotification('Teacher portal coming soon!', 'info');
                }
            }, 200);
        }

        function logout() {
            showNotification('See you soon! 👋', 'info');
            setTimeout(() => {
                document.getElementById('loginPage').style.display = 'flex';
                document.getElementById('adminDashboard').style.display = 'none';
                document.getElementById('studentDashboard').style.display = 'none';
                
                document.getElementById('email').value = '';
                document.getElementById('password').value = '';
            }, 500);
        }

        function showNotification(message, type) {
            const notification = document.createElement('div');
            notification.style.position = 'fixed';
            notification.style.top = '20px';
            notification.style.right = '20px';
            notification.style.padding = '15px 25px';
            notification.style.background = type === 'success' ? 'linear-gradient(135deg, #10b981 0%, #059669 100%)' : 
                                           type === 'info' ? 'linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)' : 
                                           'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)';
            notification.style.color = 'white';
            notification.style.borderRadius = '15px';
            notification.style.boxShadow = '0 10px 30px rgba(0,0,0,0.3)';
            notification.style.zIndex = '9999';
            notification.style.animation = 'slideIn 0.3s ease-out';
            notification.style.backdropFilter = 'blur(10px)';
            notification.style.border = '1px solid rgba(255,255,255,0.2)';
            notification.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'info' ? 'fa-info-circle' : 'fa-exclamation-circle'}"></i> ${message}`;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.style.animation = 'slideOut 0.3s ease-out';
                setTimeout(() => {
                    document.body.removeChild(notification);
                }, 300);
            }, 3000);
        }

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
        }

        // Admin navigation
        function showSection(section) {
            const sections = ['dashboard', 'analytics', 'insights', 'predictions', 'achievements', 'students', 'teachers', 'staff', 'classes', 'departments', 'batches', 'sections', 'subjects', 'curriculum', 'syllabus', 'lesson-plans', 'assignments', 'exams', 'grades', 'attendance', 'sports', 'cultural', 'clubs', 'competitions', 'workshops', 'seminars', 'field-trips', 'community', 'events', 'upcoming-events', 'past-events', 'calendar', 'registrations', 'announcements', 'messages', 'notifications', 'email', 'sms', 'push', 'feedback', 'surveys', 'newsletter', 'reports', 'custom-reports', 'certificates', 'transcripts', 'performance', 'analytics-reports', 'export', 'fees', 'payments', 'invoices', 'budget', 'scholarships', 'books', 'e-resources', 'borrowing', 'digital-library', 'health-records', 'medical', 'counseling', 'safety', 'buses', 'routes', 'tracking', 'dormitories', 'rooms', 'mess', 'users', 'roles', 'backup', 'logs', 'audit', 'integrations', 'api', 'profile', 'settings', 'security', 'notifications-settings', 'preferences', 'help', 'tickets', 'knowledge-base', 'faq', 'contact'];
            
            sections.forEach(s => {
                const element = document.getElementById(s + 'Section');
                if (element) element.style.display = 'none';
            });
            
            const selectedElement = document.getElementById(section + 'Section');
            if (selectedElement) {
                selectedElement.style.display = 'block';
            } else {
                // If section doesn't exist, show coming soon
                showNotification(`${section} section coming soon! 🚀`, 'info');
            }
            
            document.querySelectorAll('#adminDashboard .sidebar .menu-item').forEach(item => {
                item.classList.remove('active');
            });
            event.target.classList.add('active');
        }

        // Student navigation
        function showStudentSection(section) {
            const sections = ['overview', 'analytics', 'timeline', 'myAchievements', 'certificates', 'badges', 'rewards', 'hall-of-fame', 'courses', 'assignments', 'grades', 'attendance', 'timetable', 'syllabus', 'study-material', 'sports', 'cultural', 'clubs', 'competitions', 'workshops', 'volunteer', 'upcoming-events', 'registered-events', 'past-events', 'calendar', 'portfolio', 'resume', 'skills', 'projects', 'achievements-showcase', 'career-path', 'recommendations', 'internships', 'scholarships', 'college-prep', 'network', 'messages', 'notifications', 'friends', 'groups', 'forums', 'health', 'fitness', 'mindfulness', 'counseling', 'profile', 'account', 'privacy', 'preferences', 'help'];
            
            sections.forEach(s => {
                const element = document.getElementById('student' + s.charAt(0).toUpperCase() + s.slice(1));
